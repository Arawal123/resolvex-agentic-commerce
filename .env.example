# Required for production persistence. Optional for the deterministic sandbox demo.
DATABASE_URL=postgresql://resolvex:resolvex@localhost:5432/resolvex
# Optional language understanding for manual intake. The deterministic controller never receives it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
APP_URL=http://localhost:3000
AGENT_MODE=live
DEMO_MODE=true
AUTONOMY_LEVEL=bounded
MAX_AUTONOMOUS_REFUND_INR=5000
MAX_BATCH_BUDGET_INR=20000
AGENT_MAX_STEPS=15
AGENT_MAX_RETRIES=2
