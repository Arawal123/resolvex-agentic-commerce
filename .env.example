# Required for production persistence. Optional for the deterministic sandbox demo.
DATABASE_URL=postgresql://resolvex:resolvex@localhost:5432/resolvex
# Optional. When absent, ResolveX explicitly uses its deterministic sandbox controller.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
APP_URL=http://localhost:3000
AGENT_MODE=live
DEMO_MODE=true
AUTONOMY_LEVEL=bounded
MAX_AUTONOMOUS_REFUND_INR=5000
MAX_BATCH_BUDGET_INR=20000
AGENT_MAX_STEPS=15
AGENT_MAX_RETRIES=2

